<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:id="root" alignment="CENTER" prefHeight="294.0" prefWidth="446.0" spacing="20.0" stylesheets="@../styles/menu.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.AppController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label fx:id="titulo" prefHeight="29.0" prefWidth="125.0" text="Simon Dice" textAlignment="CENTER">
      <font>
         <Font name="Times New Roman" size="18.0" />
      </font></Label>
   <Button fx:id="jugar" mnemonicParsing="false" onAction="#Jugar" prefHeight="42.0" prefWidth="89.0" text="Jugar" />
   <Button fx:id="creditos" mnemonicParsing="false" onAction="#Creditos" prefHeight="35.0" prefWidth="95.0" text="Creditos" />
   <Button fx:id="salir" mnemonicParsing="false" onAction="#Salir" prefWidth="72.0" text="Salir" />
    <Button fx:id="historial" mnemonicParsing="false" onAction="#MostrarHistorial" prefHeight="42.0" prefWidth="89.0" text="Historial" />
    <MenuButton fx:id="dificultad" mnemonicParsing="false" onAction="#CambiarDificultad" text="Dificultad">
     <items>
       <MenuItem fx:id="facil" mnemonicParsing="false" onAction="#DificultadFacil" text="Facil" />
       <MenuItem fx:id="Intermedio" mnemonicParsing="false" onAction="#DificultadIntermedio" text="Normal" />
         <MenuItem fx:id="dificil" mnemonicParsing="false" onAction="#DificultadDificil" text="Dificil" />
         <MenuItem fx:id="hardcore" mnemonicParsing="false" onAction="#DificultadHardcore" text="Hardcore" />
         <MenuItem fx:id="infinito" mnemonicParsing="false" onAction="#DificultadInfinito" text="Infinito" />
     </items>
   </MenuButton>
</VBox>
