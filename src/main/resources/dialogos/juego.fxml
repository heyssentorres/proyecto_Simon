<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="panel" prefHeight="546.0" prefWidth="408.0" stylesheets="@../styles/juego.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.JuegoController">


    <Label fx:id="etiquetaRonda" layoutX="30.0" layoutY="21.0" text="Ronda: 1" />
    <Label fx:id="etiquetaRecord" layoutX="290.0" layoutY="22.0" prefHeight="18.0" prefWidth="81.0" text="Récord: 0">
      <font>
         <Font size="8.0" />
      </font></Label>
    <Button fx:id="amarillo" layoutX="30.0" layoutY="56.0" onAction="#manejarColor" prefHeight="150.0" prefWidth="150.0" style="-fx-background-color: #f25022;" />

        <Button fx:id="rojo" layoutX="220.0" layoutY="56.0" onAction="#manejarColor" prefHeight="150.0" prefWidth="150.0" style="-fx-background-color: #7fba00;" />

        <Button fx:id="azul" layoutX="30.0" layoutY="238.0" onAction="#manejarColor" prefHeight="150.0" prefWidth="150.0" style="-fx-background-color: #01A6F0;" />

        <Button fx:id="verde" layoutX="220.0" layoutY="238.0" onAction="#manejarColor" prefHeight="150.0" prefWidth="150.0" style="-fx-background-color: #ffb900;" />

    <Button fx:id="botonReiniciarRecord" layoutX="330.0" layoutY="438.0" onAction="#ReiniciarRecord" prefHeight="35.0" prefWidth="46.0" text="🔁" />

    <Button fx:id="botonReiniciar" layoutX="161.0" layoutY="439.0" onAction="#ReiniciarJuego" text="Reiniciar" />
    <HBox fx:id="velocidadBox" alignment="CENTER" layoutX="66.0" layoutY="488.0" spacing="10">
      <Label fx:id="etiquetaVelocidad" text="Velocidades">
         <font>
            <Font size="18.0" />
         </font>
      </Label>
        <Button fx:id="botonFacil" onAction="#CambiarFacil" text="Fácil" />
        <Button fx:id="botonNormal" onAction="#CambiarNormal" text="Normal" />
        <Button fx:id="botonDificil" onAction="#CambiarDificil" text="Difícil" />
    </HBox>
   <Label layoutX="133.0" layoutY="15.0" text="Simon Dice" textAlignment="CENTER" textFill="#41afc3">
      <font>
         <Font name="Times New Roman" size="27.0" />
      </font>
   </Label>
   <Pane layoutX="149.0" layoutY="404.0" prefHeight="25.0" prefWidth="105.0">
      <children>
          <Label fx:id="etiquetaAviso" layoutX="3.0" layoutY="-5.0" prefHeight="35.0" prefWidth="99.0" text="Tu turno" textAlignment="JUSTIFY">
            <font>
               <Font size="24.0" />
            </font>
         </Label>
      </children>
   </Pane>

</AnchorPane>
