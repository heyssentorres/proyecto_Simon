<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="120.0" prefWidth="374.0" styleClass="dialog-root" stylesheets="@../styles/dialogo.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.FinalPartidaController">

    <VBox alignment="CENTER" spacing="15" AnchorPane.bottomAnchor="10" AnchorPane.leftAnchor="10" AnchorPane.rightAnchor="10" AnchorPane.topAnchor="10">
        <Label fx:id="lblMensaje" style="-fx-font-size: 18px; -fx-text-fill: #333333;" styleClass="dialog-label" text="Perdiste" wrapText="true" />

        <HBox alignment="CENTER" spacing="10">
            <Button onAction="#continuar" styleClass="dialog-button" text="Volver a jugar" />
            <Button onAction="#volverMenu" styleClass="dialog-button" text="Menú principal" />
            <Button onAction="#cerrar" styleClass="dialog-button" text="Salir" />
        </HBox>
    </VBox>
</AnchorPane>
